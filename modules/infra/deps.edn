           brainard/api                          {:local/root "../api"}
           com.cognitect.aws/api                 {:mvn/version "0.8.824"}
           com.cognitect.aws/endpoints           {:mvn/version "871.2.44.8"}
           com.cognitect.aws/s3                  {:mvn/version "871.2.43.0"}
